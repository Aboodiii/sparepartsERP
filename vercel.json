{
  "version": 2,
  "builds": [
    {
      "src": "backend/package.json",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/$1",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/(.*)",
      "status": 404
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url"
  }
}
